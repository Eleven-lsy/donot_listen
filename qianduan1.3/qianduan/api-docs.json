{
  "project": "不听听力 - 四六级听力训练平台",
  "version": "1.0.0",
  "baseUrl": "http://localhost:8082",
  "description": "纯到不能再纯的四六级听力训练平台 API 接口文档",
  "updateDate": "2026-04-12",
  "notes": "所有需要认证的接口请在请求头中携带 Authorization: Bearer <token>",
  "api": [
    {
      "group": "认证相关",
      "apis": [
        {
          "method": "POST",
          "title": "用户登录",
          "path": "/api/auth/login",
          "description": "用户登录接口",
          "auth": false,
          "request": {
            "headers": [
              {"name": "Content-Type", "required": true, "description": "application/json"}
            ],
            "body": {
              "type": "object",
              "properties": {
                "username": {"type": "string", "required": true, "description": "用户名或邮箱"},
                "password": {"type": "string", "required": true, "description": "密码"}
              },
              "required": ["username", "password"]
            }
          },
          "response": {
            "success": {
              "code": 0,
              "data": {
                "userId": 123,
                "username": "testuser",
                "email": "test@example.com",
                "token": "eyJhbGci...",
                "level": 4,
                "totalListening": 0,
                "masteredCount": 0
              }
            },
            "error": {"code": -1, "msg": "用户名或密码错误"}
          },
          "example": {
            "request": "{\"username\": \"testuser\", \"password\": \"123456\"}",
            "response": "{\"code\": 0, \"msg\": \"登录成功\", \"data\": {...}}"
          }
        },
        {
          "method": "POST",
          "title": "用户注册",
          "path": "/api/auth/register",
          "description": "新用户注册账号",
          "auth": false,
          "request": {
            "headers": [
              {"name": "Content-Type", "required": true, "description": "application/json"}
            ],
            "body": {
              "type": "object",
              "properties": {
                "username": {"type": "string", "required": true, "description": "用户名（4-20位）"},
                "email": {"type": "string", "required": true, "description": "邮箱地址"},
                "password": {"type": "string", "required": true, "description": "密码（至少6位）"}
              },
              "required": ["username", "email", "password"]
            }
          },
          "response": {
            "success": {
              "code": 0,
              "data": {
                "userId": 123,
                "username": "newuser",
                "email": "new@example.com",
                "token": "eyJhbGci...",
                "level": 4,
                "totalListening": 0,
                "masteredCount": 0
              }
            },
            "error": {"code": -1, "msg": "用户名已存在"}
          },
          "example": {
            "request": "{\"username\": \"newuser\", \"email\": \"new@example.com\", \"password\": \"123456\"}",
            "response": "{\"code\": 0, \"msg\": \"注册成功\", \"data\": {...}}"
          }
        }
      ]
    },
    {
      "group": "导航相关",
      "apis": [
        {
          "method": "GET",
          "title": "获取导航数据",
          "path": "/api/navigation",
          "description": "获取首页侧边栏导航结构，包含年份/月份分组和专项训练入口",
          "auth": false,
          "request": {},
          "response": {
