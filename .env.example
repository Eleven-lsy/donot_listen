# Do Not Listen environment example
# Copy this file to `.env` and fill in real values before running locally or with Docker.

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=donot_listen
DB_USERNAME=donotlisten
DB_PASSWORD=change_me

# Docker MySQL bootstrap
MYSQL_ROOT_PASSWORD=change_me
MYSQL_USER=donotlisten
MYSQL_PASSWORD=change_me

# Auth
JWT_SECRET=replace_with_a_random_secret_at_least_32_chars

# AI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPENAI_MODEL=glm-4-flash

# Ports
APP_PORT=8082
NGINX_PORT=80
